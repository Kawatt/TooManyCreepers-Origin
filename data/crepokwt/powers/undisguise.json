{
    "name": "Release",
    "description": "You can remove yourself from the host without hurting it.",
    "type": "origins:multiple",
    "n": {
        "type": "origins:resource",
        "min": 0,
        "max": 5,
        "hud_render": {
            "should_render": false
        }
    },
    "decay": {
        "type": "origins:action_over_time",
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_n",
            "change": -1
        },
        "interval": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_n",
            "comparison": ">",
            "compare_to": 0
        }
    },
    "key": {
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_n",
                    "change": 2
                }
            ]
        },
        "cooldown": 1,
        "hud_render": {
            "should_render": false
        },
        "key": {
            "key": "key.loadToolbarActivator",
            "continuous": true
        }
    },
    "hold_or_release": {
        "type": "origins:action_over_time",
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_res",
                    "change": 1
                },
                {
                    "type": "apoli:if_else",
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:*_res",
                        "comparison": ">",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "apoli:apply_effect",
                        "effect": {
                            "effect": "minecraft:nausea",
                            "show_icon": false,
                            "is_ambient": true
                        }
                    }
                }
            ]
        },
        "interval": 1,
        "falling_action": {
            "type": "origins:change_resource",
            "resource": "*:*_res",
            "operation": "set",
            "change": 0
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_n",
            "comparison": ">",
            "compare_to": 1
        }
    },
    "res": {
        "type": "apoli:resource",
        "min": 0,
        "max": 60,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_01.png",
            "bar_index": 6,
            "condition": {
                "type": "apoli:resource",
                "resource": "*:*_res",
                "comparison": ">",
                "compare_to": 0
            }
        },
        "max_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:execute_command",
                    "command": "origin set @s origins:origin crepokwt:mimic"
                },
                {
                    "type": "apoli:apply_effect",
                    "effect": {
                        "effect": "minecraft:blindness",
                        "show_icon": false,
                        "is_ambient": true
                    }
                }
            ]
        }
    }
}