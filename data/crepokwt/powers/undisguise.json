{
    "type": "apoli:multiple",
    "res": {
        "type": "apoli:resource",
        "min": 0,
        "max": 10,
        "max_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:execute_command",
                    "command": "origin set @s origins:origin crepokwt:mimic"
                },
                {
                    "type": "apoli:play_sound",
                    "sound": "minecraft:entity.creeper.death"
                }
            ]
        }
    },
    "time": {
        "type": "apoli:action_over_time",
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "*:*_res",
            "change": -1
        }
    },
    "active": {
        "type": "apoli:active_self",
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "*:*_res",
            "change": -1
        },
        "key": {
            "key": "key.loadToolbarActivator",
            "continuous": true
        }
    }
}