{
    "type": "apoli:multiple",
    "callback": {
        "type": "apoli:action_on_callback",
        "entity_action_gained": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "scale set pehkui:height 0.5 @s"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale set pehkui:width 0.5 @s"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale set pehkui:health 0.5 @s"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale set pehkui:explosions 0 @s"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale persist set true @s"
                },
                {
                    "type": "apoli:spawn_entity",
                    "entity_type": "minecraft:armor_stand",
                    "tag": "{Tags:[\"crepokwt.spawn\",\"crepokwt.spawnaux\"],Marker:true,Invisible:0b}",
                    "entity_action": {
                        "type": "apoli:grant_power",
                        "power": "*:spruce/stand",
                        "source": "*:*"
                    }
                },
                {
                    "type": "apoli:selector_action",
                    "selector": "@e[tag=crepokwt.spawnaux,type=minecraft:armor_stand]",
                    "bientity_action": {
                        "type": "apoli:and",
                        "actions": [
                            {
                                "type": "apoli:invert",
                                "action": {
                                    "type": "apoli:delay",
                                    "ticks": 1,
                                    "action": {
                                        "type": "apoli:add_to_entity_set",
                                        "set": "*:spruce/stand_set"
                                    }
                                }
                            },
                            {
                                "type": "apoli:target_action",
                                "action": {
                                    "type": "apoli:grant_power",
                                    "power": "*:spruce/stand",
                                    "source": "*:*"
                                }
                            },
                            {
                                "type": "apoli:target_action",
                                "action": {
                                    "type": "apoli:execute_command",
                                    "command": "tag @s remove crepokwt.spawnaux"
                                }
                            }
                        ]
                    }
                }
            ]
        },
        "entity_action_added": {
            "type": "apoli:change_resource",
            "operation": "set",
            "resource": "*:*_res",
            "change": 1
        }
    },
    "res": {
        "type": "apoli:resource",
        "min": 0,
        "max": 1
    },
    "time": {
        "type": "apoli:action_over_time",
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:execute_command",
                    "command": "tag @s add crepokwt.aux"
                },
                {
                    "type": "apoli:execute_command",
                    "command": "execute as @a if score @s crepokwt.owner = @e[limit=1,sort=nearest,distance=..1,tag=crepokwt.aux] crepokwt.owner run tag @s add crepokwt.auxown"
                },
                {
                    "type": "apoli:selector_action",
                    "selector": "@a[tag=crepokwt.auxown,limit=1,sort=nearest]",
                    "bientity_action": {
                        "type": "apoli:and",
                        "actions": [
                            {
                                "type": "apoli:invert",
                                "action": {
                                    "type": "apoli:add_to_entity_set",
                                    "set": "*:spruce/set"
                                }
                            },
                            {
                                "type": "apoli:target_action",
                                "action": {
                                    "type": "apoli:execute_command",
                                    "command": "tag @s remove crepokwt.auxown"
                                }
                            },
                            {
                                "type": "apoli:actor_action",
                                "action": {
                                    "type": "apoli:change_resource",
                                    "operation": "set",
                                    "resource": "*:*_res",
                                    "change": 0
                                }
                            }
                        ]
                    }
                },
                {
                    "type": "apoli:execute_command",
                    "command": "tag @s remove crepokwt.aux"
                }
            ]
        },
        "condition": {
            "type": "apoli:resource",
            "resource": "*:*_res",
            "comparison": "==",
            "compare_to": 1
        }
    },
    "death": {
        "type": "apoli:action_over_time",
        "interval": 1,
        "rising_action": {
            "type": "origins:execute_command",
            "command": "kill @e[type=armor_stand,limit=1,sort=nearest,tag=crepokwt.spawn]"
        },
        "condition": {
            "type": "apoli:health",
            "comparison": "==",
            "compare_to": 0
        }
    }
}
