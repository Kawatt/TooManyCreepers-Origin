{
    "name": "Creeplings",
    "description": "Spawn small spruce creepers that target entities you hit.",
    "type": "apoli:multiple",
    "spawn": {
        "type": "apoli:active_self",
        "cooldown": 100,
        "hud_render": {
            "should_render": true
        },
        "key": "key.origins.secondary_active",
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:spawn_entity",
                    "entity_type": "minecraft:wolf",
                    "tag": "{Tags:[\"crepokwt.spawn\",\"crepokwt.spawnaux\"]}",
                    "entity_action": {
                        "type": "apoli:grant_power",
                        "power": "*:spruce/spawn",
                        "source": "*:*"
                    }
                },
                {
                    "type": "apoli:selector_action",
                    "selector": "@e[tag=crepokwt.spawnaux,type=minecraft:wolf]",
                    "bientity_action": {
                        "type": "apoli:and",
                        "actions": [
                            {
                                "type": "apoli:add_to_entity_set",
                                "set": "*:*_set"
                            },
                            {
                                "type": "apoli:tame"
                            }
                        ]
                    }
                }
            ]
        }
    },
    "set": {
        "type": "apoli:entity_set",
        "action_on_add": {
            "type": "apoli:target_action",
            "action": {
                "type": "apoli:execute_command",
                "command": "tag @s remove crepokwt.spawnaux"
            }
        }
    },
    "tp": {
        "type": "apoli:action_over_time",
        "entity_action": {
            "type": "apoli:action_on_entity_set",
            "set": "*:*_set",
            "bientity_action": {
                "type": "apoli:and",
                "actions": [
                    {
                        "type": "apoli:actor_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tag @s add crepokwt.spawntp"
                        }
                    },
                    {
                        "type": "apoli:target_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tp @s @p[tag=crepokwt.spawntp]"
                        }
                    },
                    {
                        "type": "apoli:actor_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tag @s remove crepokwt.spawntp"
                        }
                    }
                ]
            },
            "bientity_condition": {
                "type": "apoli:distance",
                "comparison": ">",
                "compare_to": 16
            }
        }
    },
    "attack": {
        "type": "apoli:modify_damage_dealt",
        "bientity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:actor_action",
                    "action": {
                        "type": "apoli:action_on_entity_set",
                        "set": "*:*_set",
                        "bientity_action": {
                            "type": "apoli:target_action",
                            "action": {
                                "type": "apoli:execute_command",
                                "command": "tag @s add crepokwt.spawnatk"
                            }
                        },
                        "bientity_condition": {
                            "type": "apoli:distance",
                            "comparison": "<",
                            "compare_to": 16
                        }
                    }
                },
                {
                    "type": "apoli:target_action",
                    "action": {
                        "type": "apoli:selector_action",
                        "selector": "@e[tag=crepokwt.spawnatk]",
                        "bientity_action": {
                            "type": "apoli:and",
                            "actions": [
                                {
                                    "type": "apoli:damage",
                                    "damage_type": "generic",
                                    "amount": 0
                                },
                                {
                                    "type": "apoli:target_action",
                                    "action": {
                                        "type": "apoli:execute_command",
                                        "command": "tag @s remove crepokwt.spawnatk"
                                    }
                                }
                            ]
                        }
                    }
                }
            ]
        }
    }
}