{
    "name": "Creeplings",
    "description": "Spawn small spruce creepers that target entities you hit.",
    "type": "apoli:multiple",
    "spawn": {
        "type": "apoli:active_self",
        "cooldown": 100,
        "hud_render": {
            "should_render": true
        },
        "key": "key.origins.primary_active",
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:spawn_entity",
                    "entity_type": "creeperoverhaul:spruce_creeper",
                    "tag": "{Tags:[\"crepokwt.spawn\",\"crepokwt.spawnaux\"],ExplosionRadius:0b}",
                    "entity_action": {
                        "type": "apoli:grant_power",
                        "power": "*:spruce/spawn",
                        "source": "*:*"
                    }
                },
                {
                    "type": "apoli:chance",
                    "chance": 0.9,
                    "action": {
                        "type": "apoli:spawn_entity",
                        "entity_type": "creeperoverhaul:spruce_creeper",
                        "tag": "{Tags:[\"crepokwt.spawn\",\"crepokwt.spawnaux\"],ExplosionRadius:0b}",
                        "entity_action": {
                            "type": "apoli:grant_power",
                            "power": "*:spruce/spawn",
                            "source": "*:*"
                        }
                    }
                },
                {
                    "type": "apoli:chance",
                    "chance": 0.5,
                    "action": {
                        "type": "apoli:spawn_entity",
                        "entity_type": "creeperoverhaul:spruce_creeper",
                        "tag": "{Tags:[\"crepokwt.spawn\",\"crepokwt.spawnaux\"],ExplosionRadius:0b}",
                        "entity_action": {
                            "type": "apoli:grant_power",
                            "power": "*:spruce/spawn",
                            "source": "*:*"
                        }
                    }
                },
                {
                    "type": "apoli:selector_action",
                    "selector": "@e[tag=crepokwt.spawnaux]",
                    "bientity_action": {
                        "type": "apoli:add_to_entity_set",
                        "set": "*:*_set"
                    }
                }
            ]
        }
    },
    "set": {
        "type": "apoli:entity_set",
        "action_on_add": {
            "type": "apoli:target_action",
            "action": {
                "type": "apoli:execute_command",
                "command": "tag @s remove crepokwt.spawnaux"
            }
        }
    },
    "tp": {
        "type": "apoli:action_over_time",
        "entity_action": {
            "type": "apoli:action_on_entity_set",
            "set": "*:*_set",
            "bientity_action": {
                "type": "apoli:and",
                "actions": [
                    {
                        "type": "apoli:actor_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tag @s add crepokwt.spawntp"
                        }
                    },
                    {
                        "type": "apoli:target_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tp @s @p[tag=crepokwt.spawntp]"
                        }
                    },
                    {
                        "type": "apoli:actor_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tag @s remove crepokwt.spawntp"
                        }
                    }
                ]
            },
            "bientity_condition": {
                "type": "apoli:distance",
                "comparison": ">",
                "compare_to": 8
            }
        }
    },
    "attack": {
        "type": "apoli:modify_damage_dealt",
        "bientity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:actor_action",
                    "action": {
                        "type": "apoli:trigger_cooldown",
                        "power": "*:*_cool"
                    }
                },
                {
                    "type": "apoli:actor_action",
                    "action": {
                        "type": "apoli:action_on_entity_set",
                        "set": "*:*_set",
                        "bientity_action": {
                            "type": "apoli:target_action",
                            "action": {
                                "type": "apoli:execute_command",
                                "command": "tag @s add crepokwt.spawnatk"
                            }
                        },
                        "bientity_condition": {
                            "type": "apoli:distance",
                            "comparison": "<",
                            "compare_to": 16
                        }
                    }
                },
                {
                    "type": "apoli:target_action",
                    "action": {
                        "type": "apoli:selector_action",
                        "selector": "@e[tag=crepokwt.spawnatk]",
                        "bientity_action": {
                            "type": "apoli:and",
                            "actions": [
                                {
                                    "type": "apoli:damage",
                                    "damage_type": "generic",
                                    "amount": 0
                                },
                                {
                                    "type": "apoli:target_action",
                                    "action": {
                                        "type": "apoli:execute_command",
                                        "command": "tag @s remove crepokwt.spawnatk"
                                    }
                                }
                            ]
                        }
                    }
                }
            ]
        },
        "condition": {
            "type": "apoli:resource",
            "resource": "*:*_cool",
            "comparison": "==",
            "compare_to": 0
        }
    },
    "cool": {
        "type": "apoli:cooldown",
        "cooldown": 40,
        "hud_render": {
            "should_render": false
        }
    }
}