{
    "name": "Gunpowder Explosion",
    "description": "Exploding copies your effects onto others.",
    "type": "apoli:multiple",
    "n": {
        "type": "origins:resource",
        "min": 0,
        "max": 5,
        "hud_render": {
            "should_render": false
        }
    },
    "decay": {
        "type": "origins:action_over_time",
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_n",
            "change": -1
        },
        "interval": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_n",
            "comparison": ">",
            "compare_to": 0
        }
    },
    "key": {
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:*_n",
                        "comparison": "==",
                        "compare_to": 0
                    },
                    "if_action": {
                        "type": "origins:play_sound",
                        "sound": "minecraft:entity.creeper.primed"
                    }
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_n",
                    "change": 2
                }
            ]
        },
        "cooldown": 1,
        "hud_render": {
            "should_render": false
        },
        "key": {
            "key": "key.origins.primary_active",
            "continuous": true
        },
        "condition": {
            "type": "apoli:resource",
            "resource": "*:*_cool",
            "comparison": "==",
            "compare_to": 0
        }
    },
    "hold_or_release": {
        "type": "origins:action_over_time",
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_charge",
            "change": 1
        },
        "interval": 1,
        "falling_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:if_else_list",
                    "actions": [
                        {
                            "action": {
                                "type": "apoli:and",
                                "actions": [
                                    {
                                        "type": "apoli:execute_command",
                                        "command": "function crepokwt:applyeffect"
                                    },
                                    {
                                        "type": "apoli:play_sound",
                                        "sound": "minecraft:entity.generic.explode"
                                    }
                                ]
                            },
                            "condition": {
                                "type": "apoli:resource",
                                "resource": "*:*_charge",
                                "comparison": "<",
                                "compare_to": 30
                            }
                        },
                        {
                            "action": {
                                "type": "apoli:and",
                                "actions": [
                                    {
                                        "type": "apoli:execute_command",
                                        "command": "function crepokwt:applyeffect2"
                                    },
                                    {
                                        "type": "apoli:play_sound",
                                        "sound": "minecraft:entity.generic.explode"
                                    }
                                ]
                            },
                            "condition": {
                                "type": "apoli:resource",
                                "resource": "*:*_charge",
                                "comparison": "<",
                                "compare_to": 70
                            }
                        },
                        {
                            "action": {
                                "type": "apoli:and",
                                "actions": [
                                    {
                                        "type": "apoli:execute_command",
                                        "command": "function crepokwt:applyeffect3"
                                    },
                                    {
                                        "type": "apoli:play_sound",
                                        "sound": "minecraft:entity.generic.explode"
                                    }
                                ]
                            },
                            "condition": {
                                "type": "apoli:resource",
                                "resource": "*:*_charge",
                                "comparison": "==",
                                "compare_to": 70
                            }
                        }
                    ]
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charge",
                    "operation": "set",
                    "change": 0
                },
                {
                    "type": "origins:trigger_cooldown",
                    "power": "*:*_cool"
                }
            ]
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_n",
            "comparison": ">",
            "compare_to": 1
        }
    },
    "charge": {
        "type": "apoli:resource",
        "min": 0,
        "max": 70,
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "apoli:and",
                "conditions": [
                    {
                        "type": "apoli:resource",
                        "resource": "*:*_cool",
                        "comparison": "==",
                        "compare_to": 0
                    },
                    {
                        "type": "origins:resource",
                        "resource": "*:*_n",
                        "comparison": ">",
                        "compare_to": 1
                    }
                ]
            }
        }
    },
    "cool": {
        "type": "apoli:cooldown",
        "cooldown": 70,
        "hud_render": {
            "should_render": true,
            "inverted": true,
            "condition": {
                "type": "apoli:resource",
                "resource": "*:*_cool",
                "comparison": "!=",
                "compare_to": 0
            }
        }
    },
    "slow": {
        "type": "apoli:modify_attribute",
        "attribute": "minecraft:generic.movement_speed",
        "modifier": {
            "operation": "multiply_total_multiplicative",
            "value": -0.8
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charge",
            "comparison": ">",
            "compare_to": 1
        }
    },
    "airslow": {
        "type": "origins:attribute_modify_transfer",
        "class": "modify_air_speed",
        "attribute": "minecraft:generic.movement_speed",
        "multiplier": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charge",
            "comparison": ">",
            "compare_to": 1
        }
    },
    "nosprint": {
        "type": "origins:prevent_sprinting",
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charge",
            "comparison": ">",
            "compare_to": 1
        }
    }
}